---
import type { Breadcrumb } from "../types/Breadcrumb";
import type { Testimonial } from "../types/Testimonial";
import type { Chapter } from "../types/Chapter";
import type { Cheatsheet } from "../types/Cheatsheet";

interface Objective {
  icon: string;
  title: string;
  text: string;
}

interface ProjetFilRouge {
  title: string;
  text: string;
  imgSrc: string;
  imgAlt: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  srcPicture: string;
  altPicture: string;
  courseTitle: string;
  courseDescription: string;
  courseUrl: string;
  courseTestimonials: readonly Testimonial[];
  quizUrl?: string;
  courseChapters: Chapter[];
  cheatsheets?: Cheatsheet[];
  courseLevel: string;
  courseDuration: number;
  courseAuthor: string;
  courseUpdatedDate: string;
  objectives: Objective[];
  projetFilRouge: ProjetFilRouge;
  faq: FaqItem[];
}

import BaseLayout from "./BaseLayout.astro";

const {
  altPicture,
  srcPicture,
  courseTitle,
  courseDescription,
  courseUrl,
  courseTestimonials,
  courseChapters,
  cheatsheets,
  courseLevel,
  courseDuration,
  courseAuthor,
  courseUpdatedDate,
  objectives,
  projetFilRouge,
  faq,
} = Astro.props;

const breadCrumbs: Breadcrumb[] = [
  { pageName: "Accueil", pageUrl: "/" },
  { pageName: "Cours", pageUrl: "/cours" },
  { pageName: courseTitle, pageUrl: courseUrl },
];

const sortedChapters = [...courseChapters].sort((a, b) => {
  if (a.frontmatter.sectionNumber === b.frontmatter.sectionNumber) {
    return a.frontmatter.chapterNumber - b.frontmatter.chapterNumber;
  }

  return a.frontmatter.sectionNumber - b.frontmatter.sectionNumber;
});

const sections = new Map<number, Chapter[]>();
for (const chapter of sortedChapters) {
  const sectionNumber = chapter.frontmatter.sectionNumber;
  if (!sections.has(sectionNumber)) {
    sections.set(sectionNumber, []);
  }
  sections.get(sectionNumber)?.push(chapter);
}

// Retire le préfixe "Partie N - " du titre de section pour ne garder que l'intitulé.
const cleanSectionTitle = (title: string) =>
  title.replace(/^Partie\s+\d+\s*[-–—]\s*/i, "");

const sortedCheatsheets = (cheatsheets ?? [])
  .slice()
  .sort(
    (item1, item2) =>
      new Date(item2.frontmatter.publishedDate).getTime() -
      new Date(item1.frontmatter.publishedDate).getTime(),
  )
  .slice(0, 3);

// Jeu d'icônes (contenu interne du <svg>) sélectionné par la clé `icon` des objectifs.
const OBJECTIVE_ICONS: Record<string, string> = {
  cube: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  package:
    '<path d="M4 7l8-4 8 4v10l-8 4-8-4z"/><path d="M4 7l8 4 8-4M12 11v10"/>',
  activity: '<path d="M3 12h4l3 8 4-16 3 8h4"/>',
  rocket:
    '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>',
  branch:
    '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  server:
    '<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  check: '<path d="M20 6L9 17l-5-5"/>',
};

const SITE_URL = "https://nx.academy";

const courseSchema = {
  "@type": "Course",
  name: courseTitle,
  description: courseDescription,
  url: `${SITE_URL}${courseUrl}`,
  image: `${SITE_URL}${srcPicture}`,
  inLanguage: "fr-FR",
  educationalLevel: courseLevel,
  teaches: objectives.map((objective) => objective.title),
  provider: { "@id": `${SITE_URL}/#organization` },
  offers: {
    "@type": "Offer",
    category: "Free",
    price: 0,
    priceCurrency: "EUR",
  },
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: "online",
    courseWorkload: `PT${courseDuration}H`,
  },
};

const faqSchema =
  faq.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      }
    : null;

const schemas = faqSchema ? [courseSchema, faqSchema] : [courseSchema];
---

<BaseLayout
  title={courseTitle}
  description={courseDescription}
  image={srcPicture}
  imageAlt={altPicture}
  breadcrumbs={breadCrumbs}
  schemas={schemas}
>
  <main class="course">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-body">
        <p class="kicker">Cours · {courseLevel}</p>
        <h1>{courseTitle}</h1>
        <p class="lead">{courseDescription}</p>
        <p class="byline">
          Par {courseAuthor} — mis à jour le {courseUpdatedDate}
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={courseUrl}>
            Commencer le cours
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <span class="free-note"><b>Gratuit</b>, sans inscription</span>
        </div>
      </div>
      <div class="hero-media">
        <img src={srcPicture} alt={altPicture} />
      </div>
    </section>

    <!-- Stats -->
    <div class="stats">
      <div class="stat">
        <p class="k">Durée estimée</p>
        <p class="v">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
          </svg>
          ~{courseDuration} h
        </p>
      </div>
      <div class="stat">
        <p class="k">Niveau</p>
        <p class="v">{courseLevel}</p>
      </div>
      <div class="stat">
        <p class="k">Programme</p>
        <p class="v">{courseChapters.length} chapitres</p>
      </div>
      <div class="stat">
        <p class="k">Pratique</p>
        <p class="v">Projet fil rouge</p>
      </div>
    </div>

    <!-- Objectifs -->
    <section class="sec">
      <p class="sec-kicker">Objectifs pédagogiques</p>
      <h2>Ce que vous saurez faire à la fin</h2>
      <div class="intro">
        <slot name="skills-section" />
      </div>
      <div class="obj-grid">
        {
          objectives.map((objective) => (
            <div class="obj">
              <span class="obj-ic">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={
                    OBJECTIVE_ICONS[objective.icon] ?? OBJECTIVE_ICONS.cube
                  }
                />
              </span>
              <h3>{objective.title}</h3>
              <p>{objective.text}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Programme -->
    <section class="sec">
      <p class="sec-kicker">Contenu du cours</p>
      <h2>Le programme, partie par partie</h2>
      <div class="prog">
        {
          Array.from(sections.entries()).map(([sectionNumber, chapters]) => (
            <div class="part">
              <div class="part-head">
                <span class="part-num">
                  {String(sectionNumber).padStart(2, "0")}
                </span>
                <h3>
                  {cleanSectionTitle(chapters[0].frontmatter.sectionTitle)}
                </h3>
                <span class="count">{chapters.length} chapitres</span>
              </div>
              <ul class="chapters">
                {chapters.map((chapter) => (
                  <li>
                    <a href={chapter.url}>
                      <span class="ch-n">
                        {sectionNumber}.{chapter.frontmatter.chapterNumber}
                      </span>
                      <span class="ch-title">{chapter.frontmatter.title}</span>
                      <svg
                        class="ch-arrow"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M9 6l6 6-6 6" />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- Projet fil rouge -->
      <div class="fil">
        <div class="fil-body">
          <span class="nx-pill">Projet fil rouge</span>
          <h3>{projetFilRouge.title}</h3>
          <p>{projetFilRouge.text}</p>
        </div>
        <div class="fil-media">
          <img src={projetFilRouge.imgSrc} alt={projetFilRouge.imgAlt} />
        </div>
      </div>
    </section>

    <!-- Témoignages -->
    <section class="sec">
      <p class="sec-kicker">Ils l'ont suivi</p>
      <h2>Ce qu'en disent les apprenants</h2>
      <div class="tcards">
        {
          courseTestimonials.map((testimonial) => (
            <div class="tcard">
              <p class="quote">« {testimonial.content} »</p>
              <div class="who">
                <img
                  class="ava"
                  src={testimonial.picture}
                  alt={`${testimonial.name} - ${testimonial.job}`}
                />
                <div>
                  <b>{testimonial.name}</b>
                  <span>{testimonial.job}</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- FAQ -->
    <section class="sec">
      <p class="sec-kicker">Questions fréquentes</p>
      <h2>Avant de vous lancer</h2>
      <div class="faq">
        {
          faq.map((item, index) => (
            <details class="faq-item" open={index === 0}>
              <summary>
                {item.question}
                <svg
                  class="chev"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M9 6l6 6-6 6" />
                </svg>
              </summary>
              <div class="ans">{item.answer}</div>
            </details>
          ))
        }
      </div>
    </section>

    <!-- CTA final -->
    <section class="endcta">
      <h2>Prêt·e à passer à l'action ?</h2>
      <p>
        Le cours est entièrement gratuit et accessible sans compte. Vous pouvez
        commencer tout de suite, à votre rythme.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={courseUrl}>
          Commencer le cours
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
        <a class="btn btn-ghost" href="/cours">Voir tous les cours</a>
      </div>
    </section>

    <!-- Contenu associé -->
    {
      sortedCheatsheets.length > 0 && (
        <section class="sec">
          <p class="sec-kicker">Contenu associé</p>
          <h2>Pour aller plus loin</h2>
          <div class="rel-grid">
            {sortedCheatsheets.map((cheatsheet) => (
              <a class="rcard" href={cheatsheet.url!}>
                <img
                  src={cheatsheet.frontmatter.imgSrc}
                  alt={cheatsheet.frontmatter.imgAlt}
                />
                <p class="kind">
                  {cheatsheet.frontmatter.kind ?? "Fiche technique"}
                </p>
                <h3>{cheatsheet.frontmatter.title}</h3>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .course {
    max-width: var(--container-max);
    width: var(--container-width);
    margin-inline: auto;
  }

  /* ---------- Boutons ---------- */
  .btn {
    font-size: 0.95rem;
    padding: 10px 22px;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition:
      background var(--transition),
      color var(--transition),
      border-color var(--transition);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--buttonColorPrimary);
    color: var(--buttonColorPrimaryText);
    border-color: var(--buttonColorPrimary);
    font-weight: 600;
  }
  .btn-primary:hover {
    background: var(--buttonColorPrimaryHover);
  }
  .btn-ghost {
    background: transparent;
    color: var(--linkColor);
    border-color: var(--borderPrimary);
  }
  .btn-ghost:hover {
    color: var(--linkHoverColor);
    border-color: var(--linkHoverColor);
  }

  /* ---------- Hero ---------- */
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    margin: 2rem 0 1rem;
  }
  .hero-media img {
    width: 100%;
    aspect-ratio: 1792 / 1024;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    display: block;
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.9rem;
    font-weight: 600;
  }
  .kicker::before {
    content: "";
    width: 22px;
    height: 2px;
    background: var(--accent);
    display: inline-block;
  }
  .hero h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--titleColor);
    font-size: clamp(2rem, 1.5rem + 1.8vw, 2.6rem);
    line-height: 1.12;
    margin: 0 0 1.1rem;
  }
  .hero .lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--textColor);
    margin: 0 0 1.6rem;
  }
  .hero .byline {
    font-size: 0.8rem;
    color: var(--textColor);
    margin: 0 0 1.6rem;
  }
  .hero-cta {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .free-note {
    font-size: 0.8rem;
    color: var(--textColor);
  }
  .free-note b {
    color: var(--titleColor);
    font-weight: 600;
  }

  /* ---------- Barre de stats ---------- */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border: 1px solid var(--borderPrimary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin: 2.5rem 0 3.5rem;
    background: var(--backgroundColorSecondary);
  }
  .stat {
    padding: 1.2rem 1.4rem;
    border-right: 1px solid var(--borderPrimary);
    border-bottom: 1px solid var(--borderPrimary);
  }
  .stat .k {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--textColor);
    margin: 0 0 0.35rem;
  }
  .stat .v {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--titleColor);
    font-size: 1.35rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .stat .v svg {
    color: var(--buttonColorPrimary);
    width: 18px;
    height: 18px;
  }

  /* ---------- Structure de section ---------- */
  .sec {
    margin: 0 0 3.75rem;
  }
  .sec-kicker {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .sec h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--titleColor);
    font-size: 1.85rem;
    margin: 0 0 1.3rem;
  }
  .sec .intro {
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 70ch;
    color: var(--textColor);
    margin: 0 0 1.8rem;
  }
  .sec .intro :global(p) {
    margin: 0 0 1rem;
  }
  .sec .intro :global(ul) {
    padding-left: 1.1rem;
    margin: 0 0 1rem;
  }
  .sec .intro :global(li) {
    margin-bottom: 0.4rem;
  }

  /* ---------- Objectifs ---------- */
  .obj-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .obj {
    padding: 1.4rem 1.5rem;
    border: 1px solid var(--borderPrimary);
    border-radius: var(--radius-lg);
  }
  .obj-ic {
    width: 30px;
    height: 30px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--buttonColorPrimary) 16%, transparent);
    color: var(--buttonColorPrimary);
    display: grid;
    place-items: center;
    margin: 0 0 0.9rem;
  }
  .obj-ic svg {
    width: 17px;
    height: 17px;
  }
  .obj h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--titleColor);
    font-size: 1.05rem;
    margin: 0 0 0.4rem;
    line-height: 1.25;
  }
  .obj p {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--textColor);
    margin: 0;
  }

  /* ---------- Programme ---------- */
  .prog {
    display: grid;
    gap: 1rem;
  }
  .part {
    border: 1px solid var(--borderPrimary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--backgroundColorSecondary);
  }
  .part-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--borderPrimary);
  }
  .part-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--buttonColorPrimary);
    line-height: 1;
    min-width: 2.4rem;
  }
  .part-head h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--titleColor);
    font-size: 1.2rem;
    margin: 0;
    flex: 1;
  }
  .part-head .count {
    font-size: 0.78rem;
    color: var(--textColor);
    white-space: nowrap;
  }
  .chapters {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
  }
  .chapters a {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.7rem 1.5rem;
    font-size: 0.95rem;
    color: var(--linkColor);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }
  .chapters a:hover {
    color: var(--linkHoverColor);
    background: color-mix(in srgb, var(--buttonColorPrimary) 6%, transparent);
  }
  .chapters .ch-n {
    font-size: 0.78rem;
    color: var(--textColor);
    font-variant-numeric: tabular-nums;
    min-width: 1.6rem;
  }
  .chapters .ch-title {
    flex: 1;
  }
  .chapters .ch-arrow {
    flex: 0 0 auto;
    opacity: 0.5;
  }

  /* ---------- Projet fil rouge ---------- */
  .fil {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--borderSecondary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 1rem;
  }
  .fil-body {
    padding: 2rem 2.1rem;
  }
  .fil .nx-pill {
    display: inline-block;
    border: 1px solid var(--borderSecondary);
    border-radius: var(--radius-pill);
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 2px 8px;
    margin: 0 0 1rem;
  }
  .fil h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--titleColor);
    font-size: 1.4rem;
    margin: 0 0 0.7rem;
    line-height: 1.18;
  }
  .fil p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--textColor);
    margin: 0;
  }
  .fil-media {
    position: relative;
    min-height: 220px;
    order: -1;
  }
  .fil-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---------- Témoignages ---------- */
  .tcards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .tcard {
    border: 1px solid var(--borderPrimary);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.6rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tcard .quote {
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--linkColor);
    margin: 0;
    flex: 1;
  }
  .tcard .who {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .tcard .ava {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    object-fit: cover;
    border: 1px solid var(--borderPrimary);
    flex: 0 0 auto;
  }
  .tcard .who b {
    color: var(--titleColor);
    font-weight: 600;
    font-size: 0.9rem;
    display: block;
  }
  .tcard .who span {
    font-size: 0.76rem;
    color: var(--textColor);
  }

  /* ---------- FAQ ---------- */
  .faq {
    display: grid;
    gap: 0.7rem;
  }
  details.faq-item {
