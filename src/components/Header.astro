<header>
  <div class="innner-div-wrapper">
    <div class="brand">
      <a href="/">
        <img class="brand-logo" src="/logo-mark.png" alt="" />
        NX Academy
      </a>
    </div>

    <nav class="desktop-nav">
      <a href="/fiches">Fiches techniques</a>
      <a href="/articles">Articles</a>
      <!-- <a href="/videos">Vidéos</a> -->
      <a href="/cours">Cours</a>
      <a href="/jeux">Jeux vidéo</a>
      <a href="/quiz">Quiz</a>
    </nav>

    <button class="theme-btn" type="button" aria-label="Changer le thème">
      <svg
        class="moon-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg
        class="sun-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M8 22H16"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M5 19H19"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M2 16H22"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M12 6C8.68629 6 6 8.68629 6 12C6 13.5217 6.56645 14.911 7.5 15.9687H16.5C17.4335 14.911 18 13.5217 18 12C18 8.68629 15.3137 6 12 6Z"
          stroke="currentColor"
          stroke-width="1.5"></path>
        <path
          d="M12 2V3"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
        <path
          d="M22 12L21 12"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
        <path
          d="M3 12L2 12"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
        <path
          d="M19.0708 4.92969L18.678 5.32252"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
        <path
          d="M5.32178 5.32227L4.92894 4.92943"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
      <svg
        class="summer-icon"
        viewBox="0 0 512 512"
        xmlns="http://www.w3.org/2000/svg"
      >
        <use xlink:href="#beach-icon"></use>
      </svg>
    </button>

    <button
      class="burger"
      type="button"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
      <a href="/fiches">Fiches techniques</a>
      <a href="/articles">Articles</a>
      <!-- <a href="/videos">Vidéos</a> -->
      <a href="/cours">Cours</a>
      <a href="/jeux">Jeux vidéo</a>
      <a href="/quiz">Quiz</a>
    </nav>
  </div>

  <div class="summer-waves" aria-hidden="true">
    <div class="wave wave-1"></div>
    <div class="wave wave-2"></div>
  </div>
</header>

<style>
  header {
    align-items: center;
    background-color: var(--backgroundColorPrimary);
    border-bottom: 1px solid var(--borderPrimary);
    display: flex;
    justify-content: space-between;
    position: relative;
    z-index: 100;
    margin-bottom: 1.5rem;
  }

  .innner-div-wrapper {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-left: auto;
    margin-right: auto;
    max-width: 1100px;
    padding-bottom: 1.5rem;
    padding-top: 1.5rem;
    width: 90%;
  }

  .brand a {
    align-items: center;
    color: var(--linkColor);
    display: inline-flex;
    font-family: "Pixelify Sans", sans-serif;
    font-size: 1.4rem;
    gap: 10px;
    white-space: nowrap;

    &:hover {
      color: var(--linkHoverColor);
    }
  }

  .brand-logo {
    width: 30px;
    height: 30px;
    image-rendering: pixelated;
  }

  a {
    text-decoration: none;
    color: var(--linkColor);
    font-size: 1.0625rem;
    transition: color 0.3s ease;
  }

  a:hover {
    color: var(--linkHoverColor);
  }

  .desktop-nav {
    display: none;
  }

  .moon-icon,
  .sun-icon,
  .summer-icon {
    display: none;
  }

  html.theme-dark .moon-icon {
    display: block;
  }

  html.theme-light .sun-icon {
    display: block;
  }

  html.theme-summer .summer-icon {
    display: block;
    fill: currentColor;
  }

  .theme-btn {
    align-items: center;
    background: none;
    border: 1px solid var(--borderPrimary);
    border-radius: 999px;
    color: var(--linkColor);
    cursor: pointer;
    display: flex;
    height: 34px;
    justify-content: center;
    margin-left: auto;
    margin-right: 24px;
    padding: 0;
    transition:
      color 0.3s ease,
      border-color 0.3s ease;
    width: 34px;
  }

  .theme-btn:hover {
    color: var(--linkHoverColor);
    border-color: var(--linkHoverColor);
  }

  .theme-btn svg {
    height: 20px;
    width: 20px;
  }

  .burger {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 32px;
    height: 24px;
    cursor: pointer;
    z-index: 1001;
    background: none;
    border: none;
    padding: 0;
  }

  .burger span {
    height: 4px;
    width: 100%;
    background-color: var(--burgerColor);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .burger:hover span {
    background-color: var(--burgerHoverColor);
  }

  .burger.active span:nth-child(1) {
    transform: rotate(45deg) translateY(10px);
  }

  .burger.active span:nth-child(2) {
    opacity: 0;
  }

  .burger.active span:nth-child(3) {
    transform: rotate(-45deg) translateY(-10px);
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    width: 80vw;
    max-width: 320px;
    height: 100vh;
    background: var(--backgroundColorMobileNav);
    backdrop-filter: blur(6px);
    transform: translateX(100%);
    opacity: 0;
    visibility: hidden;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      visibility 0s linear 0.3s;
    z-index: 1000;
    padding: 5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .mobile-nav.active {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      visibility 0s linear 0s;
  }

  @media screen and (min-width: 1024px) {
    .innner-div-wrapper {
      justify-content: unset;
      gap: 32px;
    }

    .desktop-nav {
      display: flex;
      gap: 2rem;
    }

    .theme-btn {
      margin-right: 0;
    }

    .burger,
    .mobile-nav {
      display: none !important;
    }
  }

  /* Décor de vagues — uniquement en thème été */
  .summer-waves {
    display: none;
  }

  html.theme-summer .summer-waves {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 10px;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  html.theme-summer .summer-waves .wave {
    position: absolute;
    bottom: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    background-repeat: repeat-x;
    will-change: transform;
  }

  html.theme-summer .summer-waves .wave-1 {
    background-image: radial-gradient(
      circle at 10px -4px,
      transparent 10px,
      #0a9396 11px
    );
    background-size: 20px 10px;
    opacity: 0.55;
    animation: summer-wave-move 7s linear infinite;
  }

  html.theme-summer .summer-waves .wave-2 {
    background-image: radial-gradient(
      circle at 12px -4px,
      transparent 12px,
      #94d2bd 13px
    );
    background-size: 24px 10px;
    opacity: 0.4;
    animation: summer-wave-move-2 11s linear infinite reverse;
  }

  @keyframes summer-wave-move {
    to {
      transform: translate3d(-20px, 0, 0);
    }
  }

  @keyframes summer-wave-move-2 {
    to {
      transform: translate3d(-24px, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.theme-summer .summer-waves .wave {
      animation: none;
    }
  }
</style>

<script>
  const $burger = document.querySelector(".burger") as HTMLButtonElement;
  const $mobileNav = document.querySelector(".mobile-nav") as HTMLElement;
  const $body = document.body as HTMLBodyElement;

  const $themeBtn = document.querySelector(".theme-btn") as HTMLElement;

  const THEMES = ["theme-light", "theme-dark", "theme-summer"];

  $themeBtn.addEventListener("click", function () {
    const root = document.documentElement;
    const current =
      THEMES.find((t) => root.classList.contains(t)) ?? "theme-light";
    const next = THEMES[(THEMES.indexOf(current) + 1) % THEMES.length];

    root.classList.remove(...THEMES);
    root.classList.add(next);
    localStorage.setItem("theme", next);
  });

  function setMenu(isOpen: boolean) {
    $burger.classList.toggle("active", isOpen);
    $mobileNav.classList.toggle("active", isOpen);
    $burger.setAttribute("aria-expanded", String(isOpen));
    $burger.setAttribute(
      "aria-label",
      isOpen ? "Fermer le menu" : "Ouvrir le menu",
    );
    $mobileNav.setAttribute("aria-hidden", String(!isOpen));

    if (isOpen) {
      $body.style.overflow = "hidden";
      $body.style.height = "100vh";
    } else {
      $body.style.overflow = "";
      $body.style.height = "";
    }
  }

  $burger.addEventListener("click", () => {
    setMenu(!$burger.classList.contains("active"));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && $burger.classList.contains("active")) {
      setMenu(false);
      $burger.focus();
    }
  });
</script>
