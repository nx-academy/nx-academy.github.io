---
import type { News } from "../types/News";
interface Props {
  newsFeed: News[];
}

import Heading3 from "./Heading3.astro";
import NewsCard from "./News.astro";

const { newsFeed } = Astro.props;
---

<a class="feed-link" href="/feed">
  <span class="feed-title">
    <Heading3 content="Le Feed" />
    <span class="live">En direct</span>
  </span>
  <svg class="chevron-icon" viewBox="0 0 24 24">
    <use xlink:href="#arrow-icon"></use>
  </svg>
</a>
<ul class="news-feed">
  {
    newsFeed.map((news) => (
      <li>
        <NewsCard
          content={news.content}
          published={news.published}
          slug={news.slug}
          title={news.title}
        />
      </li>
    ))
  }
</ul>

<style>
  .feed-link {
    align-items: center;
    display: flex;
    gap: 4px;
    margin-bottom: 1.5rem;

    @media screen and (min-width: 90rem) {
      margin-bottom: 2rem;
    }
  }

  .feed-title {
    align-items: center;
    display: inline-flex;
    gap: 0.55rem;
  }

  .feed-title :global(h3) {
    white-space: nowrap;
  }

  .live {
    border: 1px solid var(--borderSecondary);
    border-radius: 999px;
    color: var(--accent);
    font-size: 0.62rem;
    letter-spacing: 0.07em;
    padding: 2px 7px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .feed-link .chevron-icon {
    height: 32px;
    width: 32px;
    fill: none;
    stroke: var(--linkColor);
  }

  .feed-link:hover {
    h3 {
      color: var(--linkHoverColor);
    }
  }

  ul {
    padding-left: 0;
    list-style-type: none;
    display: flex;
    overflow: scroll;
    gap: 32px;

    @media screen and (min-width: 48rem) {
      gap: 36px;
      overflow: unset;
      flex-direction: column;
      border-left: 1px solid var(--borderPrimary);
      padding-left: 16px;
    }
  }

  li {
    min-width: 80%;

    @media screen and (min-width: 48rem) {
      min-width: unset;
    }
  }
</style>
