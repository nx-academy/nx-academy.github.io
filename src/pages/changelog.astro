---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Changelog";
const pageDescription =
  "NX Academy est regulièrement mis à jour. J'utilise cette page pour vous tenir au courant des derniers fixes et fonctionnalités.";

import { getCollection } from "astro:content";
import type { LogTasks } from "../types/LogTasks";

import MontlyChangelog from "../components/Changelog.astro";

const entries = await getCollection("changelog");

// tri décroissant : année puis order (mois)
entries.sort(
  (a, b) => b.data.year - a.data.year || b.data.order - a.data.order,
);

// regroupement { [year]: LogTasks[] }
const byYear = new Map<number, LogTasks[]>();
for (const { data } of entries) {
  const list = byYear.get(data.year) ?? [];
  list.push({ month: data.month, tasks: data.tasks });
  byYear.set(data.year, list);
}
const years = [...byYear.keys()].sort((a, b) => b - a); // plus récent en premier
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="main-wrapper">
    <h1>Changelog</h1>
    <div class="changelog-description">
      <div class="changelog-notice" role="note">
        <p>
          ✨ <strong
            >Ce changelog s'appuie désormais sur une mécanique plus simple et
            durable.</strong
          > Chaque mois est maintenant un fichier versionné dans le dépôt, au lieu
          de données saisies à la main dans le code. Concrètement, ça me permet de
          le tenir à jour plus facilement et plus régulièrement.
        </p>
        <p>
          Petite transparence : entre avril 2026 et la mise en place de cette
          nouvelle mécanique, le journal a pris du retard alors que le projet
          continuait d'évoluer (refonte de nombreuses pages). Je vais rattraper
          les mois manquants progressivement. Merci de votre patience 🙂
        </p>
      </div>
      <p>
        Merci de prendre le temps de consulter ce changelog. Si le terme ne vous
        est pas familier, sachez qu’il s’agit simplement <strong
          >d’un journal de mise à jour</strong
        >. L’idée ici est de vous tenir au courant des évolutions de NX Academy
        : nouvelles fonctionnalités, corrections, ajustements.
      </p>
      <p>
        Pour votre information, je travaille sur la nouvelle version de NX
        Academy depuis environ 9 mois. Cela dit, je n'ai pas tout le temps eu
        autant de temps que je l'aurais souhaité pour travailler dessus. <strong
          >J'ai lancé ce changelog en Avril 2025.</strong
        > Je vais continuer à le mettre à jour après ce mois et j'essayerais d'ajouter
        des dates avant, dans la mesure du possible.
      </p>
      <p>Bonne lecture 🙂 !</p>
    </div>
    {
      years.map((year, i) => (
        <>
          {i > 0 && <hr />}
          <MontlyChangelog
            monthlyChangelog={byYear.get(year)!}
            year={" " + year}
          />
        </>
      ))
    }
  </main>
</BaseLayout>

<style>
  .main-wrapper {
    width: 90%;
    margin-left: auto;
    margin-right: auto;
    max-width: 1100px;
    max-inline-size: 66ch;
  }

  .changelog-description {
    padding-top: 24px;
    margin-bottom: 56px;
  }

  .changelog-notice {
    margin-bottom: 40px;
    padding: 16px 20px;
    border: 1px solid var(--articleLinkColor);
    border-left: 4px solid var(--articleLinkColor);
    border-radius: 8px;
    background-color: color-mix(
      in srgb,
      var(--articleLinkColor) 8%,
      transparent
    );
  }

  .changelog-notice p {
    margin-bottom: 12px;
  }

  .changelog-notice p:last-child {
    margin-bottom: 0;
  }

  h1 {
    margin-top: 0;
  }

  h2 {
    margin-bottom: 24px;
  }

  h3 {
    margin-bottom: 8px;
  }

  p,
  li {
    margin-bottom: 24px;
    color: var(--textColor);
    font-size: clamp(0.875rem, 0.75rem + 1.5vw, 1.125rem);
  }

  a {
    color: var(--articleLinkColor);

    &:hover {
      color: var(--articleLinkHoverColor);
    }
  }
</style>
