<script>
  (function () {
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const els = Array.from(
      document.querySelectorAll<HTMLElement>("[data-reveal]"),
    );
    const tl = document.getElementById("timeline");

    function animateCount(el: HTMLElement) {
      const target = Number(el.dataset.count);
      const suffix = el.dataset.suffix || "";
      const dur = 1100;
      let start: number | null = null;
      function step(t: number) {
        if (start === null) start = t;
        const p = Math.min((t - start) / dur, 1);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(e * target) + suffix;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function runCounts(scope: ParentNode) {
      scope.querySelectorAll<HTMLElement>("[data-count]").forEach(animateCount);
    }

    // Etat final immediat si l'utilisateur prefere moins d'animation.
    if (reduce) {
      els.forEach((e) => e.classList.add("in"));
      if (tl) tl.classList.add("in");
      document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
        el.textContent = (el.dataset.count || "") + (el.dataset.suffix || "");
      });
      return;
    }

    function show(e: HTMLElement) {
      if (e.classList.contains("in")) return;
      e.classList.add("in");
      if (e.querySelector("[data-count]")) runCounts(e);
    }

    // IntersectionObserver natif (fiable hors iframe), avec filet de securite.
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              show(entry.target as HTMLElement);
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -8% 0px" },
      );
      els.forEach((e) => io.observe(e));

      if (tl) {
        const tlio = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                tlio.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -15% 0px" },
        );
        tlio.observe(tl);
      }
    } else {
      els.forEach(show);
      if (tl) tl.classList.add("in");
    }

    // Filet de securite : si rien ne s'est declenche, tout reveler.
    window.setTimeout(() => {
      els.forEach(show);
      if (tl) tl.classList.add("in");
    }, 1600);
  })();
</script>
