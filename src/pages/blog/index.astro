---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro"
const allPosts = await Astro.glob('./posts/*.md')
---

<BlogPostLayout title="Bienvenue sur le blog de NX Academy" meta="Retrouvez les derniers billets de NX Academy. Faites votre veille simplement, gratuitement et sans engagement. Découvrez l'actualité en lien avec le JavaScript, React, Node, Bun, Astro et bien plus.">
    <h1>Blog</h1>
    <hr>
    <ul>
        {
            allPosts.map(post => (
                <li>
                    <img src={post.frontmatter.image.src} alt={post.frontmatter.image.alt} />
                    <div>
                        <h3>{post.frontmatter.title}</h3>
                        <p>{post.frontmatter.description}</p>
                        <a href={post.url}>Lire le billet</a>
                    </div>
                </li>
            ))
        }
    </ul>
</BlogPostLayout>

<style>
    ul {
        list-style-type: none;
        padding-left: 0;
    }

    li {
        align-items: flex-start;
        display: flex;
    }

    h3,
    p {
        margin: 0;
    }

    p {
        margin-bottom: 8px
    }

    img {
        height: 100px;
        margin-right: 24px;
        width: auto;
    }

    a {
        margin-top: auto;
        text-decoration: underline;
    }
</style>
